{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://plausible.io https://plausible.mythos-agent.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://img.shields.io; font-src 'self'; connect-src 'self' https://plausible.io https://plausible.mythos-agent.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        }
      ]
    },
    {
      "source": "/(.+)\\.(js|css|woff2|svg|png|jpg|webp|avif|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/github", "destination": "https://github.com/mythos-agent/mythos-agent", "permanent": false },
    { "source": "/npm", "destination": "https://www.npmjs.com/package/mythos-agent", "permanent": false },
    { "source": "/sponsor", "destination": "https://github.com/sponsors/zhijiewong", "permanent": false },
    { "source": "/vision", "destination": "https://github.com/mythos-agent/mythos-agent/blob/main/VISION.md", "permanent": false },
    { "source": "/roadmap", "destination": "https://github.com/mythos-agent/mythos-agent/blob/main/ROADMAP.md", "permanent": false },
    { "source": "/docs", "destination": "https://github.com/mythos-agent/mythos-agent#readme", "permanent": false },
    { "source": "/discord", "destination": "https://discord.com/invite/PLACEHOLDER", "permanent": false }
  ]
}
