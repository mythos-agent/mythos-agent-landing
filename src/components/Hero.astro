---
import { Image } from 'astro:assets';
import cerby from '../assets/cerby-hero.svg';
import CopyCommand from './CopyCommand.astro';
import { site } from '../lib/site';
---

<section id="top" class="hero">
  <div class="hero-inner">
    <div class="copy">
      <p class="eyebrow">
        <span>Open-source</span>
        <span class="dot">·</span>
        <span>MIT</span>
        <span class="dot">·</span>
        <span>v{site.version}</span>
      </p>

      <h1 class="display">
        AI code review for application security.
      </h1>

      <p class="subhead">
        Mythos Agent reasons about your code the way a security-focused
        reviewer would — generating hypotheses, hunting CVE variants, and
        ranking findings by confidence.
      </p>

      <div class="ctas">
        <CopyCommand command="npx mythos-agent scan" label="Quick scan" tone="primary" />
        <a class="gh-cta" href={site.repo.url} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="18" height="18">
            <path d="M12 .5C5.73.5.5 5.74.5 12.02c0 5.08 3.29 9.39 7.86 10.91.58.1.79-.25.79-.56v-1.96c-3.2.7-3.87-1.54-3.87-1.54-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.72-1.55-2.56-.29-5.25-1.28-5.25-5.71 0-1.26.45-2.29 1.19-3.1-.12-.29-.51-1.47.11-3.07 0 0 .97-.31 3.18 1.18.92-.26 1.9-.39 2.88-.4.98.01 1.96.14 2.88.4 2.2-1.49 3.17-1.18 3.17-1.18.63 1.6.23 2.78.11 3.07.74.81 1.18 1.84 1.18 3.1 0 4.44-2.7 5.41-5.28 5.69.41.36.78 1.06.78 2.15v3.18c0 .31.21.67.8.56 4.57-1.52 7.85-5.83 7.85-10.91C23.5 5.74 18.27.5 12 .5z"/>
          </svg>
          <span>View on GitHub</span>
          <img
            class="star-badge"
            src={site.repo.shieldsStars}
            alt=""
            loading="lazy"
            decoding="async"
            width="76"
            height="20"
          />
        </a>
      </div>

      <p class="tertiary">
        <a href={`${site.repo.url}/blob/main/VISION.md`} target="_blank" rel="noopener">
          Read the Vision <span aria-hidden="true">→</span>
        </a>
      </p>

      <ul class="trust-row" role="list">
        <li>{site.stats.scannerCategories} scanner categories</li>
        <li>{site.stats.builtInRules} rules</li>
        <li>{site.stats.languages} languages</li>
        <li>Claude · GPT-4o · Ollama · offline</li>
      </ul>
    </div>

    <div class="mascot" aria-hidden="true">
      <div class="mascot-glow"></div>
      <Image src={cerby} alt="" widths={[320, 480, 640]} sizes="(max-width: 900px) 60vw, 420px" loading="eager" />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        50% 60% at 80% 20%,
        var(--glow) 0%,
        transparent 70%
      ),
      radial-gradient(
        40% 40% at 10% 80%,
        var(--accent-soft) 0%,
        transparent 80%
      );
    pointer-events: none;
    z-index: 0;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 72rem;
    margin: 0 auto;
    padding: 5rem 1.25rem 4rem;
    display: grid;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 900px) {
    .hero-inner {
      grid-template-columns: 1.2fr 1fr;
      padding: 6rem 1.25rem 5rem;
      gap: 4rem;
    }
  }
  .eyebrow {
    display: inline-flex;
    gap: 0.6rem;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin: 0 0 1rem;
    padding: 0.375rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: 9999px;
    background: var(--bg-raised);
  }
  .dot {
    color: var(--text-subtle);
  }
  .display {
    font-family: var(--font-display);
    font-size: clamp(2.25rem, 5vw, 4.25rem);
    line-height: 1.04;
    letter-spacing: -0.03em;
    font-weight: 700;
    margin: 0 0 1.25rem;
    color: var(--text);
    text-wrap: balance;
  }
  .subhead {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--text-muted);
    max-width: 36rem;
    margin: 0 0 1.75rem;
  }
  .ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
    margin: 0 0 1rem;
  }
  .gh-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1rem;
    border-radius: 0.625rem;
    border: 1px solid var(--border-strong);
    background: var(--bg-raised);
    color: var(--text);
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    transition:
      border-color 0.15s ease,
      background 0.15s ease;
  }
  .gh-cta:hover {
    border-color: var(--accent);
  }
  .star-badge {
    height: 20px;
    width: auto;
    border-radius: 0.25rem;
  }
  .tertiary {
    margin: 0 0 2rem;
    font-size: 0.9375rem;
  }
  .tertiary a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }
  .tertiary a:hover {
    text-decoration: underline;
  }
  .trust-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    padding: 0;
    margin: 0;
    list-style: none;
    font-size: 0.8125rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
  }
  .trust-row li {
    position: relative;
  }
  .trust-row li + li::before {
    content: '·';
    position: absolute;
    left: -0.8rem;
    color: var(--text-subtle);
  }
  .mascot {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .mascot :global(img) {
    width: 100%;
    max-width: 420px;
    height: auto;
    filter: drop-shadow(0 20px 40px var(--glow));
  }
  .mascot-glow {
    position: absolute;
    inset: 10% 10%;
    border-radius: 50%;
    background: radial-gradient(circle, var(--glow), transparent 70%);
    filter: blur(40px);
    z-index: -1;
  }
</style>
