---
import { site } from '../lib/site';

const tabs = [
  {
    id: 'quick',
    label: 'Quick scan',
    hint: 'No API key · pattern mode',
    lang: 'bash',
    code: `npx mythos-agent scan`,
  },
  {
    id: 'hunt',
    label: 'Full AI hunt',
    hint: 'BYO LLM · deep pipeline',
    lang: 'bash',
    code: `npx mythos-agent hunt`,
  },
  {
    id: 'global',
    label: 'Global install',
    hint: 'Pin a stable version',
    lang: 'bash',
    code: `npm install -g mythos-agent@${site.version}`,
  },
  {
    id: 'action',
    label: 'GitHub Action',
    hint: 'Scan on push · SARIF upload',
    lang: 'yaml',
    code: `- name: Mythos Agent scan
  uses: mythos-agent/action@v1
  with:
    fail-on: high
    upload-sarif: true`,
  },
];
---

<section id="install" class="install">
  <div class="wrap">
    <h2 class="section-label">Install</h2>
    <h3 class="section-title">Four ways to start. All of them take under a minute.</h3>

    <div class="tabs-root">
      <div class="tablist" role="tablist" aria-label="Installation options">
        {
          tabs.map((t, i) => (
            <button
              type="button"
              role="tab"
              id={`tab-${t.id}`}
              aria-controls={`panel-${t.id}`}
              aria-selected={i === 0 ? 'true' : 'false'}
              tabindex={i === 0 ? 0 : -1}
              class="tab"
              data-tab={t.id}
            >
              <span class="tab-label">{t.label}</span>
              <span class="tab-hint">{t.hint}</span>
            </button>
          ))
        }
      </div>

      {
        tabs.map((t, i) => (
          <div
            id={`panel-${t.id}`}
            role="tabpanel"
            aria-labelledby={`tab-${t.id}`}
            class="panel"
            data-panel={t.id}
            hidden={i !== 0}
          >
            <div class="code-frame">
              <pre class:list={['code', `lang-${t.lang}`]}><code>{t.code}</code></pre>
              <button
                type="button"
                class="panel-copy"
                data-copy={t.code}
                aria-label={`Copy ${t.label}`}
              >
                <svg class="copy-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
                <svg class="check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </button>
            </div>
          </div>
        ))
      }
    </div>

    <div class="satellites">
      <a href={`${site.repo.url}/tree/main/action`} target="_blank" rel="noopener">
        GitHub Action docs <span aria-hidden="true">→</span>
      </a>
      <a href={`${site.repo.url}/tree/main/vscode-extension`} target="_blank" rel="noopener">
        VS Code extension <span aria-hidden="true">→</span>
      </a>
      <a href={site.npm.url} target="_blank" rel="noopener">
        npm package <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const root = document.querySelector('.tabs-root');
    if (!root) return;
    const tabs = Array.from(root.querySelectorAll('[role="tab"]'));
    const panels = Array.from(root.querySelectorAll('[role="tabpanel"]'));
    const activate = (id) => {
      tabs.forEach((t) => {
        const match = t.getAttribute('data-tab') === id;
        t.setAttribute('aria-selected', match ? 'true' : 'false');
        t.setAttribute('tabindex', match ? '0' : '-1');
      });
      panels.forEach((p) => {
        p.hidden = p.getAttribute('data-panel') !== id;
      });
    };
    tabs.forEach((t, i) => {
      t.addEventListener('click', () => activate(t.getAttribute('data-tab')));
      t.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
          e.preventDefault();
          const dir = e.key === 'ArrowRight' ? 1 : -1;
          const next = tabs[(i + dir + tabs.length) % tabs.length];
          next.focus();
          activate(next.getAttribute('data-tab'));
        }
      });
    });

    root.querySelectorAll('.panel-copy').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const code = btn.getAttribute('data-copy') || '';
        try {
          if (navigator.clipboard) {
            await navigator.clipboard.writeText(code);
          } else {
            const ta = document.createElement('textarea');
            ta.value = code;
            ta.style.position = 'absolute';
            ta.style.left = '-9999px';
            document.body.appendChild(ta);
            ta.select();
            // Fallback for non-secure contexts; clipboard API is preferred above.
            document.execCommand('copy');
            document.body.removeChild(ta);
          }
          btn.classList.add('copied');
          setTimeout(() => btn.classList.remove('copied'), 1600);
        } catch (_) {
          /* ignore */
        }
      });
    });
  })();
</script>

<style>
  .install {
    padding: 4rem 1.25rem;
    border-top: 1px solid var(--border);
  }
  .wrap {
    max-width: 72rem;
    margin: 0 auto;
  }
  .section-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: 0 0 2rem;
    max-width: 40rem;
  }
  .tabs-root {
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    overflow: hidden;
    background: var(--bg-raised);
  }
  .tablist {
    display: grid;
    grid-template-columns: 1fr;
    border-bottom: 1px solid var(--border);
  }
  @media (min-width: 640px) {
    .tablist {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .tab {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
    padding: 0.9rem 1.1rem;
    text-align: left;
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--border);
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease;
  }
  @media (min-width: 640px) {
    .tab {
      border-bottom: 0;
      border-right: 1px solid var(--border);
    }
    .tab:last-child {
      border-right: 0;
    }
  }
  .tab:hover {
    background: var(--accent-soft);
    color: var(--text);
  }
  .tab[aria-selected='true'] {
    background: var(--bg-elevated);
    color: var(--text);
    box-shadow: inset 0 -2px 0 var(--accent);
  }
  .tab-label {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9375rem;
    letter-spacing: -0.01em;
  }
  .tab-hint {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--text-subtle);
  }
  .panel {
    position: relative;
  }
  .code-frame {
    position: relative;
  }
  .code {
    margin: 0;
    padding: 1.25rem 3.5rem 1.25rem 1.25rem;
    background: var(--code-bg);
    color: var(--code-fg);
    font-family: var(--font-mono);
    font-size: 0.875rem;
    line-height: 1.6;
    overflow-x: auto;
    white-space: pre;
  }
  .panel-copy {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    width: 2rem;
    height: 2rem;
    padding: 0;
    border-radius: 0.375rem;
    border: 1px solid var(--border);
    background: var(--bg-raised);
    color: var(--text-muted);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
  }
  .panel-copy:hover {
    color: var(--text);
    border-color: var(--accent);
  }
  .copy-icon,
  .check-icon {
    width: 0.9375rem;
    height: 0.9375rem;
  }
  .check-icon {
    display: none;
    color: var(--color-sev-verified);
  }
  .panel-copy.copied .copy-icon {
    display: none;
  }
  .panel-copy.copied .check-icon {
    display: block;
  }
  .satellites {
    margin-top: 1.25rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    font-size: 0.875rem;
  }
  .satellites a {
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }
  .satellites a:hover {
    text-decoration: underline;
  }
</style>
