---
interface Props {
  command: string;
  label?: string;
  tone?: 'primary' | 'secondary';
}

const { command, label, tone = 'primary' } = Astro.props;
---

<button
  type="button"
  class:list={['copy-cmd', tone]}
  data-command={command}
  aria-label={label ? `Copy command: ${label}` : `Copy: ${command}`}
>
  <span class="prompt" aria-hidden="true">$</span>
  <code>{command}</code>
  <svg
    class="copy-icon"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
  </svg>
  <svg
    class="check-icon"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <polyline points="20 6 9 17 4 12"></polyline>
  </svg>
  <span class="sr-only status" aria-live="polite"></span>
</button>

<script is:inline>
  document.querySelectorAll('.copy-cmd').forEach((btn) => {
    const cmd = btn.getAttribute('data-command') || '';
    const status = btn.querySelector('.status');
    btn.addEventListener('click', async () => {
      try {
        if (navigator.clipboard) {
          await navigator.clipboard.writeText(cmd);
        } else {
          const ta = document.createElement('textarea');
          ta.value = cmd;
          ta.setAttribute('readonly', '');
          ta.style.position = 'absolute';
          ta.style.left = '-9999px';
          document.body.appendChild(ta);
          ta.select();
          // Fallback for non-secure contexts; clipboard API is preferred above.
          document.execCommand('copy');
          document.body.removeChild(ta);
        }
        btn.classList.add('copied');
        if (status) status.textContent = 'Copied';
        setTimeout(() => {
          btn.classList.remove('copied');
          if (status) status.textContent = '';
        }, 1600);
      } catch (_) {
        if (status) status.textContent = 'Copy failed';
      }
    });
  });
</script>

<style>
  .copy-cmd {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1rem;
    border-radius: 0.625rem;
    border: 1px solid var(--border-strong);
    background: var(--bg-raised);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    line-height: 1;
    cursor: pointer;
    position: relative;
    min-width: 0;
    transition:
      border-color 0.15s ease,
      background 0.15s ease,
      transform 0.05s ease;
  }
  .copy-cmd.primary {
    border-color: var(--accent);
    background: var(--bg-raised);
    box-shadow: 0 0 0 0 var(--glow);
  }
  .copy-cmd.primary:hover {
    box-shadow: 0 0 0 4px var(--glow);
  }
  .copy-cmd:hover {
    border-color: var(--accent);
  }
  .copy-cmd:active {
    transform: translateY(1px);
  }
  .prompt {
    color: var(--accent);
    font-weight: 700;
    user-select: none;
  }
  code {
    font: inherit;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .copy-icon,
  .check-icon {
    width: 1rem;
    height: 1rem;
    color: var(--text-muted);
    flex-shrink: 0;
  }
  .check-icon {
    display: none;
    color: var(--color-sev-verified);
  }
  .copy-cmd.copied .copy-icon {
    display: none;
  }
  .copy-cmd.copied .check-icon {
    display: block;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
