---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import DemoEmbed from '../components/DemoEmbed.astro';
import FeatureGrid from '../components/FeatureGrid.astro';
import HowItWorks from '../components/HowItWorks.astro';
import ScannerMatrix from '../components/ScannerMatrix.astro';
import TrustSignals from '../components/TrustSignals.astro';
import InstallBlock from '../components/InstallBlock.astro';
import SponsorCTA from '../components/SponsorCTA.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Nav />
  <main id="main">
    <Hero />
    <DemoEmbed />
    <FeatureGrid />
    <HowItWorks />
    <ScannerMatrix />
    <TrustSignals />
    <InstallBlock />
    <SponsorCTA />
  </main>
  <Footer />
</BaseLayout>
